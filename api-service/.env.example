# ============================================================
# WG-FUX API — Configuration Template (v6.4 Production-Ready)
# Copier ce fichier vers .env et remplir TOUTES les valeurs.
# AVERTISSEMENT : Ne jamais commiter le fichier .env dans Git.
# ============================================================

# --- Serveur API ---
PORT=3000
NODE_ENV=production

# --- Sécurité JWT (OBLIGATOIRE) ---
# Générer via : openssl rand -hex 64
JWT_SECRET=CHANGE_ME_openssl_rand_hex_64

# --- Admin par défaut (OBLIGATOIRE) ---
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=  # Généré automatiquement par setup.sh
ADMIN_PASSWORD_SALT=  # Généré automatiquement par setup.sh

# --- CORS (OBLIGATOIRE en Production) ---
# Indiquer le ou les domaine(s) autorisés, séparés par des virgules.
# Exemple : https://vpn.mondomaine.com
# LAISSER VIDE = wildcard '*' => INTERDIT EN PRODUCTION
ALLOWED_ORIGINS=https://VOTRE_DOMAINE.com

# --- Watchdog Sentinel (OBLIGATOIRE) ---
# Token secret pour le watchdog interne. Générer via : openssl rand -hex 32
SENTINEL_TOKEN=CHANGE_ME_openssl_rand_hex_32

# --- Mode revendeur : provisioning des VPS distants (one-liner) ---
# Clé maître AES-256-GCM chiffrant les clés privées SSH des VPS en base
# (services/crypto.js). OBLIGATOIRE pour le mode revendeur. 32 bytes = 64 hex.
# Générer via : openssl rand -hex 32  — NE JAMAIS la commiter ni la perdre.
WG_FUX_MASTER_KEY=CHANGE_ME_openssl_rand_hex_32
# URL publique de la plateforme (sert le templating du one-liner + le tarball).
# Si vide, reconstruite depuis la requête entrante.
PLATFORM_BASE_URL=
# IP publique de la plateforme : injectée dans authorized_keys (from="IP") sur le
# VPS revendeur — seule cette IP peut utiliser la clé SSH cantonnée.
PLATFORM_PUBLIC_IP=
# Épinglage de la clé publique TLS (cert pinning, format sha256//...) durcissant
# le curl du one-liner contre un MITM. Optionnel (vide = pas de pinning).
TLS_PINNED_PUBKEY=

# --- WireGuard ---
WG_INTERFACE=wg0
WG_PORT=51820
SERVER_IP=  # Votre IP publique VPS
VPN_SUBNET=10.0.0.1
VPN_SUBNET_V6=fd00::1

# MTU 1280 : Anti-fragmentation 4G/5G (Gaming Mobile Optimisé)
# MTU 1420 : Standard WireGuard (recommandé pour usage général)
SERVER_MTU=1280

CLIENT_DNS=1.1.1.1,8.8.8.8
PERSISTENT_KEEPALIVE=5

# --- AdGuard Home (AGH) ---
# Identifiants pour l'API AdGuard (utilisez ceux configurés au premier accès)
AGH_USER=admin
AGH_PASSWORD=admin_password
# URL de l'API AdGuard Home (optionnel — override si AdGuard n'est pas sur le réseau Docker par défaut)
# AGH_BASE_URL=http://adguard:3000

# --- Observabilité (P12) ---
# Niveaux : DEBUG, INFO, WARN, ERROR, AUDIT
LOG_LEVEL=INFO
# Formats : json (prod), pretty (dev)
LOG_FORMAT=json

# --- Chemins Système ---
WG_CLIENTS_DIR=/etc/wireguard/clients
# Optionnel — overrides binaires
# WG_BIN=wg
# WG_QUICK_BIN=wg-quick
# SUDO_BIN=sudo

# --- Notifications (optionnels) ---
# Telegram bot (alertes via core-vpn/scripts/wg-send-msg.sh)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Webhook générique (Slack/Discord/...) pour notify.send
# WEBHOOK_URL=
# SMTP (mail alerts — réservé pour futur)
# SMTP_HOST=

# --- Observabilité (optionnel) ---
# SENTRY_DSN=
# DEBUG=false

# --- Backups chiffrés (OBLIGATOIRE pour wg-backup.sh / wg-restore.sh) ---
# Passphrase de chiffrement AES-256 — générer via : openssl rand -base64 32
# BACKUP_PASSPHRASE=
# BACKUP_DIR=/app/backups
# BACKUP_RETENTION_DAYS=30
