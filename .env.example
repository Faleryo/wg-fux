# --- System Config ---
SERVER_PORT="51820"            # WireGuard UDP port (set by setup.sh)
SERVER_IP="0.0.0.0"            # Public IP / domain for WireGuard endpoint (set by setup.sh)
DOMAIN="example.com"           # Domain for Let's Encrypt SSL
EMAIL="admin@example.com"      # Email for Let's Encrypt
WG_INTERFACE="wg0"             # WireGuard interface name

# --- AdGuard Home ---
# IMPORTANT: AdGuard Home requires a password of at least 8 characters.
AGH_USER="admin"
AGH_PASSWORD="CHANGE_ME_MIN_8_CHARS"

# --- Security ---
# JWT_SECRET: Used for session tokens. Use a long random string.
JWT_SECRET="CHANGE_ME_LONG_RANDOM_STRING"
# SENTINEL_TOKEN: Used by the Watchdog script. MUST match the one in Sentinel.
SENTINEL_TOKEN="CHANGE_ME_RANDOM_STRING"
# WG_FUX_MASTER_KEY: AES-256-GCM master key encrypting reseller VPS SSH private
# keys at rest (services/crypto.js). 32 bytes = 64 hex. Generate: openssl rand -hex 32
WG_FUX_MASTER_KEY="CHANGE_ME_openssl_rand_hex_32"
# Reseller provisioning (one-liner) — see docs spec 2026-06-30
PLATFORM_BASE_URL=""
PLATFORM_PUBLIC_IP=""
TLS_PINNED_PUBKEY=""

# --- Admin ---
ADMIN_USER="admin"
ADMIN_PASSWORD_HASH="PBKDF2_HASH_HERE"
ADMIN_PASSWORD_SALT="SALT_HERE"

# --- API ---
ALLOWED_ORIGINS="http://localhost,https://localhost,http://127.0.0.1:3000"

