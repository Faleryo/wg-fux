# 💠 WG-FUX Platinum .gitignore

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js / React (UI)
dashboard-ui/.next/
dashboard-ui/out/
dashboard-ui/dist/
dashboard-ui/build/

# Coverage / Test artifacts
coverage/
api-service/coverage/
.nyc_output/

# Scratch / debug
scratch/
api-service/scratch/
api-service/check-db.js
api-service/test-hash.js
scripts/evil-pentest.sh

# Environnement & Secrets (CRITIQUE)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
api-service/.env
api-service/.env.local
api-service/.env.bak*
core-vpn/scripts/sentinel.env

# Bases de données & Persistance
api-service/data/*.db
api-service/data/*.db-shm
api-service/data/*.db-wal
api-service/data/temp/

# Infrastructure & SSL (sensitive — remove from tracking if already committed)
infra/ssl/*
!infra/ssl/.gitkeep

# WireGuard & Système
# Note: les chemins /etc/wireguard sont gérés hors du dépôt git
# Les fichiers .conf sont exclus via *.key et *.conf globs ci-dessous
*.conf
# Exception : la conf nginx du dashboard est du code applicatif, pas un secret WG
!dashboard-ui/nginx.conf
!infra/nginx/default.conf
*.key
*.psk

# Logs
logs/
*.log
*.txt
api-service/logs/
*.pid

# Autres
.DS_Store
.vscode/
.idea/
*.swp
*.bak

# Vibe-OS & Tooling (privé — jamais sur le repo public)
.vibe
.vibe/

protected-bundle/
