# 💠 WG-FUX Platinum .gitignore

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js / React (UI)
dashboard-ui/.next/
dashboard-ui/out/
# dashboard-ui/dist/ (Autorisé pour SRE Pre-build sur VPS 458MB)
dashboard-ui/build/

# Environnement & Secrets (CRITIQUE)s
.env.local
.env.development.local
.env.test.local
.env.production.local
api-service/.env
api-service/.env.local

# Bases de données & Persistance
api-service/data/*.db
api-service/data/*.db-shm
api-service/data/*.db-wal
api-service/data/temp/

# Infrastructure & SSL
infra/ssl/*.key
infra/ssl/*.crt
infra/ssl/*.pem
!infra/ssl/.gitkeep

# WireGuard & Système
/etc/wireguard/*
!/etc/wireguard/templates/
*.key
*.psk

# Logs
logs/
*.log
*.txt
api-service/logs/

# Autres
.DS_Store
.vscode/
.idea/
*.swp
*.bak
# Vibe-OS & Tooling (privé — jamais sur le repo public)

# Markdown interne (hors README)
!README.md

